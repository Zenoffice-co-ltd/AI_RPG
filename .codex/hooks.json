{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$(git rev-parse --show-toplevel)/.codex/hooks/pre_tool_use_policy.mjs\"",
            "statusMessage": "Checking destructive command policy"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$(git rev-parse --show-toplevel)/.codex/hooks/user_prompt_skill_router.mjs\"",
            "statusMessage": "Routing repo skills"
          }
        ]
      }
    ]
  }
}
