# Secret Manager retrieval and mutation rules.
#
# Source of Truth: repository-root AGENTS.md `## Secrets` section.
# This file is the Codex-side enforcement of that SoT and is shared with
# Cursor / Claude Code / Codex agents that read AGENTS.md.
#
# Canonical retrieval pattern (allowed without prompt — read-only):
#   gcloud secrets versions access latest \
#     --secret=<NAME> --project=<PROJECT>
#
# Project precedence (per AGENTS.md `## Secrets`):
#   1. ENV variable already set in the current shell
#   2. apps/web/.env.local (gitignored, local-only — never commit)
#   3. Secret Manager: SECRET_SOURCE_PROJECT_ID env var
#      → fallback `zapier-transfer`
#      → fallback `adecco-mendan` (per-tenant secrets such as XAI_API_KEY,
#         ELEVENLABS_API_KEY)
#
# Operational scripts that need a live API key MUST resolve via this
# precedence at runtime (see scripts/grok-voice-v21-scenario-e2e.ts
# `loadXaiKeyFromSecretManagerIfNeeded` for the canonical resolver shape)
# and exit with an explicit "BLOCKED: <NAME> not available" message if
# none of the sources yields a real key (length >= 32, not a "test-…"
# placeholder).
#
# Secret aliases matter. Adecco browser E2E often needs env
# `DEMO_ACCESS_TOKEN` from secret `demo-access-token`; v25/v50 relay routes
# need `XAI_RELAY_TICKET_SECRET`; normal Grok voice paths need `XAI_API_KEY`.
# On Windows, Node `spawn("gcloud", ...)` can fail to resolve `gcloud.ps1`.
# Scripts must prefer already-set env vars, support a Windows-friendly fallback
# where practical, and never print secret values beyond length-only diagnostics.
#
# NEVER:
#   - hard-code keys in the repo
#   - commit keys to .env*, config/*, scripts/*
#   - paste keys into PR descriptions, issue comments, chat transcripts,
#     or commit messages
#   - write keys to disk anywhere outside the user's local-only
#     apps/web/.env.local
#   - print keys to logs or console output beyond a length-only debug line

prefix_rule(
    pattern = ["gcloud", "secrets", "delete"],
    decision = "forbidden",
    justification = "Deleting a Secret Manager secret removes ALL versions and breaks every runtime / script / Cloud Run service that resolves it via `gcloud secrets versions access latest`. Agents must never delete secrets. If a key truly needs to be retired, the human operator owns the decommission flow.",
    match = [
        "gcloud secrets delete XAI_API_KEY --project=zapier-transfer",
        "gcloud secrets delete ELEVENLABS_API_KEY --project=adecco-mendan",
    ],
    not_match = [
        "gcloud secrets list --project=zapier-transfer",
        "gcloud secrets describe XAI_API_KEY --project=zapier-transfer",
    ],
)

prefix_rule(
    pattern = ["gcloud", "secrets", "versions", "destroy"],
    decision = "forbidden",
    justification = "Destroying a Secret Manager version is irreversible and will break runtime once the destroyed version becomes 'latest'. If a version must be taken offline, use `gcloud secrets versions disable` (reversible via `enable`) instead.",
    match = [
        "gcloud secrets versions destroy 5 --secret=XAI_API_KEY --project=zapier-transfer",
    ],
    not_match = [
        "gcloud secrets versions access latest --secret=XAI_API_KEY --project=zapier-transfer",
        "gcloud secrets versions list --secret=XAI_API_KEY --project=zapier-transfer",
        "gcloud secrets versions disable 5 --secret=XAI_API_KEY --project=zapier-transfer",
    ],
)

prefix_rule(
    pattern = ["gcloud", "secrets", "versions", "add"],
    decision = "prompt",
    justification = "Adding a new secret version overwrites what runtime services read via `access latest`, which immediately rotates the key for every consumer (Cloud Run mendan, App Hosting, ConvAI webhooks, local dev scripts). Confirm: (1) source of the new value, (2) target project (zapier-transfer vs adecco-mendan — per-tenant key family matters), (3) downstream consumers can tolerate immediate rotation, and (4) the old version is left alive for rollback. See AGENTS.md `## Secrets`.",
    match = [
        "gcloud secrets versions add XAI_API_KEY --data-file=- --project=zapier-transfer",
        "gcloud secrets versions add ELEVENLABS_API_KEY --data-file=key.txt --project=adecco-mendan",
    ],
    not_match = [
        "gcloud secrets versions access latest --secret=XAI_API_KEY --project=zapier-transfer",
        "gcloud secrets versions list --secret=XAI_API_KEY --project=zapier-transfer",
    ],
)

prefix_rule(
    pattern = ["gcloud", "secrets", "create"],
    decision = "prompt",
    justification = "Creating a new Secret Manager secret expands the runtime surface and requires matching IAM grants (Cloud Run service account, App Hosting service account, GitHub Actions WIF). Confirm the name is consistent across projects (case-sensitive), the IAM trio is planned, and the consumer code is ready to read it. See `.agents/skills/ai-rpg-adecco-roleplay-ab-backends/SKILL.md` § Secret Manager.",
    match = [
        "gcloud secrets create NEW_API_KEY --project=zapier-transfer",
        "gcloud secrets create NEW_API_KEY --replication-policy=automatic --project=adecco-mendan",
    ],
    not_match = [
        "gcloud secrets list --project=zapier-transfer",
    ],
)

prefix_rule(
    pattern = ["gcloud", "secrets", "set-iam-policy"],
    decision = "prompt",
    justification = "Replacing a Secret Manager IAM policy can revoke production access for Cloud Run / App Hosting service accounts in a single command. Prefer `add-iam-policy-binding` for additive grants; only use `set-iam-policy` after reviewing the full target policy file.",
    match = [
        "gcloud secrets set-iam-policy XAI_API_KEY policy.json --project=zapier-transfer",
    ],
    not_match = [
        "gcloud secrets get-iam-policy XAI_API_KEY --project=zapier-transfer",
        "gcloud secrets add-iam-policy-binding XAI_API_KEY --member=serviceAccount:foo --role=roles/secretmanager.secretAccessor --project=zapier-transfer",
    ],
)

prefix_rule(
    pattern = ["gcloud", "secrets", "add-iam-policy-binding"],
    decision = "prompt",
    justification = "Secret Manager IAM grants can expose production secrets or unblock App Hosting builds. Confirm the target project, secret name, service account, role, and whether this is the App Hosting IAM trio (`secretAccessor`, `viewer`, Firebase App Hosting service agent `secretVersionManager`).",
    match = [
        "gcloud secrets add-iam-policy-binding XAI_API_KEY --project=adecco-mendan --member=serviceAccount:firebase-app-hosting-compute@adecco-mendan.iam.gserviceaccount.com --role=roles/secretmanager.secretAccessor",
    ],
    not_match = [
        "gcloud secrets get-iam-policy XAI_API_KEY --project=adecco-mendan",
    ],
)
