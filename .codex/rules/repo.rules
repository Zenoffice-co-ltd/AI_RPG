prefix_rule(
    pattern = ["git", "reset", "--hard"],
    decision = "forbidden",
    justification = "Do not discard worktree state with `git reset --hard`. Use a targeted revert or reviewed recovery plan instead.",
    match = [
        "git reset --hard",
        "git reset --hard HEAD~1",
    ],
    not_match = [
        "git reset --soft HEAD~1",
    ],
)

prefix_rule(
    pattern = ["git", "checkout", "--"],
    decision = "forbidden",
    justification = "Do not use `git checkout --` to discard local changes. Restore specific files with a reviewed action instead.",
    match = [
        "git checkout -- README.md",
        "git checkout -- packages/scenario-engine/src/compileAccountingScenario.ts",
    ],
    not_match = [
        "git checkout codex/accounting-phase34-v2",
    ],
)

prefix_rule(
    pattern = ["git", "clean", "-fd"],
    decision = "forbidden",
    justification = "Do not remove untracked files with `git clean -fd`. Generated evidence and local artifacts must be reviewed before cleanup.",
    match = [
        "git clean -fd",
        "git clean -fd tmp",
    ],
    not_match = [
        "git clean -n",
    ],
)

prefix_rule(
    pattern = ["pnpm", "publish:scenario"],
    decision = "prompt",
    justification = "Publishing mutates external vendor state. Confirm the scenario id, environment, readiness evidence, and whether generated publish snapshots are evidence-only or intended for commit.",
    match = [
        "pnpm publish:scenario -- --scenario staffing_order_hearing_busy_manager_medium",
        "pnpm publish:scenario -- --scenario accounting_clerk_enterprise_ap_busy_manager_medium",
    ],
    not_match = [
        "pnpm compile:scenarios",
    ],
)

prefix_rule(
    pattern = ["pnpm", "verify:acceptance"],
    decision = "prompt",
    justification = "Acceptance is the canonical release gate. If it blocks, preserve targeted substep evidence and record non-task blockers in docs/OPERATIONS.md before merge.",
    match = [
        "pnpm verify:acceptance",
        "pnpm verify:acceptance -- --preflight",
    ],
    not_match = [
        "pnpm test",
    ],
)

prefix_rule(
    pattern = ["pnpm", "deploy:adecco-roleplay"],
    decision = "prompt",
    justification = "App Hosting deploys are long-running and mutate production. Confirm the short diagnostic ladder first: route session API identity, App Hosting vs relay ownership, required secrets/IAM, expected prompt/guardrail version, and the post-deploy smoke/log commands to run.",
    match = [
        "pnpm deploy:adecco-roleplay",
        "pnpm deploy:adecco-roleplay -- --skip-verify",
    ],
    not_match = [
        "pnpm deploy:adecco-roleplay -- --skip-deploy",
    ],
)

prefix_rule(
    pattern = ["pnpm", "deploy:adecco-roleplay:gcloud"],
    decision = "prompt",
    justification = "The gcloud App Hosting deploy path creates a production build/rollout. Confirm Firebase CLI is actually blocked or gcloud is explicitly requested, and record the expected route-specific post-deploy checks before starting.",
    match = [
        "pnpm deploy:adecco-roleplay:gcloud",
    ],
    not_match = [
        "pnpm deploy:adecco-roleplay:gcloud -- --skip-deploy",
    ],
)

prefix_rule(
    pattern = ["firebase", "deploy"],
    decision = "prompt",
    justification = "Bare Firebase deploy bypasses the repo wrapper's baseline, warm-cache, and post-deploy verification evidence. Use `pnpm deploy:adecco-roleplay` unless debugging Cloud Build, and document why the wrapper is not used.",
    match = [
        "firebase deploy --only apphosting",
        "npx firebase deploy --only apphosting",
    ],
    not_match = [
        "firebase deploy --help",
    ],
)

prefix_rule(
    pattern = ["gcloud", "run", "deploy"],
    decision = "prompt",
    justification = "Cloud Run relay deploys mutate the shared realtime transport. Confirm App Hosting session API is healthy, the change is relay-owned, required relay secrets are present, and relay health/log checks will be run after deploy.",
    match = [
        "gcloud run deploy xai-realtime-relay",
    ],
    not_match = [
        "gcloud run services describe xai-realtime-relay",
    ],
)

prefix_rule(
    pattern = ["node", ".codex_tmp"],
    decision = "prompt",
    justification = "Do not repeatedly use temporary harnesses as release evidence. If the flow is reusable, promote it to scripts/, add a package script, make secret resolution fail closed, and record the scoped denominator.",
    match = [
        "node .codex_tmp/v50_7_prod_voice_turn_e2e.mjs",
        "node .codex_tmp/v50_7_voice_e2e.mjs",
    ],
    not_match = [
        "node scripts/grok-first-v50-prod-smoke.mjs",
    ],
)

prefix_rule(
    pattern = ["git", "worktree", "remove"],
    decision = "prompt",
    justification = "Removing a worktree can delete local baseline evidence. Confirm the target path is temporary and inside the intended workspace before removal.",
    match = [
        "git worktree remove --force tmp/pre-adecco-baseline",
        "git worktree remove tmp/baseline",
    ],
    not_match = [
        "git worktree list",
    ],
)

prefix_rule(
    pattern = ["git", "merge"],
    decision = "prompt",
    justification = "Before merging, update README/docs for workflow or behavior changes, refresh repo skills or Codex safety config if the workflow changed, confirm current verification evidence, and explicitly separate any out-of-scope blockers.",
    match = [
        "git merge codex/accounting-phase34-v2",
        "git merge --no-ff main",
    ],
    not_match = [
        "git merge-base main HEAD",
    ],
)

prefix_rule(
    pattern = ["gh", "pr", "merge"],
    decision = "prompt",
    justification = "Before merging a PR, confirm docs/runbooks, repo skills, Codex safety config, release verification evidence, and any human-evidence blockers are documented for the final state.",
    match = [
        "gh pr merge 5 --squash",
        "gh pr merge https://github.com/iwase-cpu/AI_RPG/pull/5 --merge",
    ],
    not_match = [
        "gh pr view 5",
    ],
)
