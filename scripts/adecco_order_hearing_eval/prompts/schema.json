{
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "session_id",
    "scenario_id",
    "total_score",
    "score_confidence",
    "grade_label",
    "rubric_scores",
    "must_capture_summary",
    "must_capture_items",
    "agent_quality_flags",
    "sales_compliance_flags",
    "modality_limitations",
    "strengths",
    "improvement_points",
    "learner_feedback",
    "next_training_actions",
    "scoring_notes"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "enum": ["adecco_order_hearing_eval_v2"]
    },
    "session_id": { "type": "string" },
    "scenario_id": { "type": "string" },
    "total_score": { "type": "number", "minimum": 0, "maximum": 100 },
    "score_confidence": {
      "type": "string",
      "enum": ["high", "medium", "low"]
    },
    "grade_label": {
      "type": "string",
      "enum": ["S", "A", "B", "C", "D"]
    },
    "rubric_scores": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "coverage",
        "hearing_skill",
        "priority_clarity",
        "deal_structure",
        "business_behavior",
        "closing"
      ],
      "properties": {
        "coverage": { "$ref": "#/$defs/rubricScore" },
        "hearing_skill": { "$ref": "#/$defs/rubricScore" },
        "priority_clarity": { "$ref": "#/$defs/rubricScore" },
        "deal_structure": { "$ref": "#/$defs/rubricScore" },
        "business_behavior": { "$ref": "#/$defs/rubricScore" },
        "closing": { "$ref": "#/$defs/rubricScore" }
      }
    },
    "must_capture_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "weighted_capture_ratio",
        "count_capture_ratio",
        "captured_count",
        "partial_count",
        "missed_count",
        "weighted_coverage_points"
      ],
      "properties": {
        "weighted_capture_ratio": { "type": "number", "minimum": 0, "maximum": 1 },
        "count_capture_ratio": { "type": "number", "minimum": 0, "maximum": 1 },
        "captured_count": { "type": "integer", "minimum": 0 },
        "partial_count": { "type": "integer", "minimum": 0 },
        "missed_count": { "type": "integer", "minimum": 0 },
        "weighted_coverage_points": { "type": "number", "minimum": 0, "maximum": 30 }
      }
    },
    "must_capture_items": {
      "type": "array",
      "minItems": 12,
      "maxItems": 12,
      "items": { "$ref": "#/$defs/mustCaptureItem" }
    },
    "must_capture_groups": {
      "type": "array",
      "minItems": 0,
      "maxItems": 8,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["group_id", "group_label", "items"],
        "properties": {
          "group_id": { "type": "string" },
          "group_label": { "type": "string" },
          "items": {
            "type": "array",
            "minItems": 1,
            "items": { "$ref": "#/$defs/mustCaptureItem" }
          }
        }
      }
    },
    "agent_quality_flags": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "hidden_fact_leakage",
        "coaching_leakage",
        "role_break",
        "transcript_quality_issue",
        "scoring_blocker",
        "details"
      ],
      "properties": {
        "hidden_fact_leakage": { "type": "boolean" },
        "coaching_leakage": { "type": "boolean" },
        "role_break": { "type": "boolean" },
        "transcript_quality_issue": { "type": "boolean" },
        "scoring_blocker": { "type": "boolean" },
        "details": {
          "type": "array",
          "items": { "$ref": "#/$defs/flagDetail" }
        }
      }
    },
    "sales_compliance_flags": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "inappropriate_demographic_requirement_deepened",
        "inappropriate_requirement_reframed",
        "details"
      ],
      "properties": {
        "inappropriate_demographic_requirement_deepened": { "type": "boolean" },
        "inappropriate_requirement_reframed": { "type": "boolean" },
        "details": {
          "type": "array",
          "items": { "$ref": "#/$defs/flagDetail" }
        }
      }
    },
    "modality_limitations": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    },
    "strengths": {
      "type": "array",
      "items": { "type": "string" },
      "maxItems": 5
    },
    "improvement_points": {
      "type": "array",
      "items": { "type": "string" },
      "maxItems": 5
    },
    "learner_feedback": {
      "type": "string"
    },
    "next_training_actions": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" },
      "maxItems": 5
    },
    "scoring_notes": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "$defs": {
    "rubricScore": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "label",
        "max_points",
        "rubric_score_0_to_4",
        "points",
        "reason",
        "evidence"
      ],
      "properties": {
        "label": { "type": "string" },
        "max_points": { "type": "number" },
        "rubric_score_0_to_4": { "type": "number", "minimum": 0, "maximum": 4 },
        "points": { "type": "number", "minimum": 0 },
        "reason": { "type": "string" },
        "evidence": {
          "type": "array",
          "items": { "$ref": "#/$defs/evidence" },
          "maxItems": 3
        }
      }
    },
    "mustCaptureItem": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "label",
        "weight_points",
        "capture_level",
        "captured_by_sales",
        "client_disclosed_without_prompt",
        "judgement",
        "missing_detail",
        "evidence"
      ],
      "properties": {
        "id": { "type": "integer", "minimum": 1, "maximum": 12 },
        "label": { "type": "string" },
        "weight_points": {
          "type": ["number", "null"]
        },
        "capture_level": {
          "type": "number",
          "enum": [0, 0.5, 1]
        },
        "captured_by_sales": { "type": "boolean" },
        "client_disclosed_without_prompt": { "type": "boolean" },
        "judgement": {
          "type": "string",
          "enum": ["captured", "partial", "missed"]
        },
        "missing_detail": { "type": ["string", "null"] },
        "evidence": {
          "type": "array",
          "items": { "$ref": "#/$defs/evidence" },
          "maxItems": 2
        }
      }
    },
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["turn_id", "speaker", "quote", "why_relevant"],
      "properties": {
        "turn_id": { "type": "string" },
        "speaker": {
          "type": "string",
          "enum": ["sales", "client", "unknown"]
        },
        "quote": { "type": "string" },
        "why_relevant": { "type": "string" }
      }
    },
    "flagDetail": {
      "type": "object",
      "additionalProperties": false,
      "required": ["flag_type", "turn_id", "quote", "impact"],
      "properties": {
        "flag_type": {
          "type": "string",
          "enum": [
            "hidden_fact_leakage",
            "coaching_leakage",
            "role_break",
            "transcript_quality_issue",
            "scoring_blocker",
            "inappropriate_demographic_requirement_deepened",
            "inappropriate_requirement_reframed"
          ]
        },
        "turn_id": { "type": ["string", "null"] },
        "quote": { "type": ["string", "null"] },
        "impact": { "type": "string" }
      }
    }
  }
}
